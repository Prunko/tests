@model IEnumerable<ht16.Models.Film>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My films</h1>

    <a asp-action="Create" class="btn btn-success"> + Add a film </a>
</div>

<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <input type="number" name="searchYear" class="form-control"
               placeholder="Рік" value="@ViewBag.CurrentYear">
    </div>

    <div class="col-auto">
        <select name="searchGenre" class="form-select">
            <option value="">All genres</option>
            @foreach (var genre in ViewBag.Genres)
            {
                if (genre == ViewBag.CurrentGenre)
                {
                    <option value="@genre" selected>@genre</option>
                }
                else
                {
                    <option value="@genre">@genre</option>
                }
            }
        </select>
    </div>

    <div class="col-auto">
        <button type="submit" class="btn btn-secondary">Use filters:</button>
        <a asp-action="Index" class="btn btn-outline-dark">Back</a>
    </div>
</form>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Director</th>
            <th>Genre</th>
            <th>Year</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model)
        {
            <tr>
                <td>@film.Title</td>
                <td>@film.Director</td>
                <td>@film.Genre</td>
                <td>@film.Year</td>
                <td class="text-center">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@film.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@film.Id" class="btn btn-outline-danger btn-sm">Remove</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>